{
  "version": 2,
  "builds": [
    {
      "src": "hotel-website/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/hotel-website/static/(.*)",
      "dest": "/hotel-website/static/$1"
    },
    {
      "src": "/hotel-website/(.*)",
      "dest": "/hotel-website/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/hotel-website/index.html"
    }
  ]
}
